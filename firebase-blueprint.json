{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Company member of the union",
      "type": "object",
      "properties": {
        "cnpj": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["cnpj", "name", "email", "status"]
    },
    "Boleto": {
      "title": "Boleto",
      "description": "Financial document for a member",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "title", "amount", "dueDate", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Official announcement for all members",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["alert", "info", "event"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "createdAt"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "User feedback or suggestion",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "createdAt"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Automatically generated FAQ from user queries",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "relevance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "question", "answer", "updatedAt"]
    },
    "LegalQuery": {
      "title": "LegalQuery",
      "description": "Legal query submitted by accountant",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "companyCNPJ": { "type": "string" },
        "companyName": { "type": "string" },
        "subject": { "type": "string" },
        "question": { "type": "string" },
        "category": { "type": "string" },
        "urgency": { "type": "string" },
        "assignedLawyer": { "type": "string" },
        "assignedLawyerEmail": { "type": "string" },
        "aiAnalysis": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "replyText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "companyCNPJ", "companyName", "subject", "question", "category", "urgency", "assignedLawyer", "assignedLawyerEmail", "aiAnalysis", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log of site configuration changes made by admins",
      "type": "object",
      "properties": {
        "adminEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "changes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["adminEmail", "timestamp", "changes"]
    },
    "BillingConfig": {
      "title": "BillingConfig",
      "description": "Configuration for automatic due date calculation of guides and slips",
      "type": "object",
      "properties": {
        "defaultDaysToDue": { "type": "number" },
        "acceptWeekendPayment": { "type": "boolean" },
        "calculationMethod": { "type": "string" },
        "workdays": {
          "type": "object",
          "properties": {
            "monday": { "type": "boolean" },
            "tuesday": { "type": "boolean" },
            "wednesday": { "type": "boolean" },
            "thursday": { "type": "boolean" },
            "friday": { "type": "boolean" },
            "saturday": { "type": "boolean" },
            "sunday": { "type": "boolean" }
          }
        },
        "holidays": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      },
      "required": ["defaultDaysToDue", "acceptWeekendPayment", "calculationMethod", "workdays"]
    },
    "PushSubscription": {
      "title": "PushSubscription",
      "description": "Web push subscription payload",
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "keys": {
          "type": "object",
          "properties": {
            "p256dh": { "type": "string" },
            "auth": { "type": "string" }
          },
          "required": ["p256dh", "auth"]
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["endpoint", "keys"]
    },
    "PublishedDocument": {
      "title": "PublishedDocument",
      "description": "Document uploaded by admin for publication",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "vigence": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "fileData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "vigence", "fileName", "fileData", "createdAt"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Board member or employee of the union",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "category": { "type": "string", "enum": ["presidencia", "diretoria", "gerencia", "atendimento"] },
        "photo": { "type": "string" }
      },
      "required": ["name", "role", "category"]
    }
  },
  "firestore": {
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Board members and employees shown in the organizational chart"
    },
    "/published_documents/{documentId}": {
      "schema": "PublishedDocument",
      "description": "Uploaded documents available for members to download"
    },
    "/push_subscriptions/{subscriptionId}": {
      "schema": "PushSubscription",
      "description": "Browser push notification subscriptions"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of union members"
    },
    "/members/{memberId}/boletos/{boletoId}": {
      "schema": "Boleto",
      "description": "Sub-collection of boletos for a specific member"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Global notifications"
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "User suggestions and feedback"
    },
    "/faq/{faqId}": {
      "schema": "FAQ",
      "description": "Collection of frequently asked questions"
    },
    "/plantao_juridico/{queryId}": {
      "schema": "LegalQuery",
      "description": "Collection of legal queries submitted to the Plantão Jurídico"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Log entries for administrative settings changes"
    },
    "/settings/{settingId}": {
      "schema": "BillingConfig",
      "description": "Global settings documents including site config and billing config"
    }
  }
}
