rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: assumes a collection /admins/ where docId is the email
    function isAdmin() { 
      return isSignedIn() && 
             'email' in request.auth.token && (
               request.auth.token.email == 'cleciotecnologia@gmail.com' ||
               exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
             );
    }

    function isSuperUser() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email == 'cleciotecnologia@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validation Blueprints ---

    function isValidAdmin(data) {
      return data.email is string && ('email' in request.auth.token && data.email == request.auth.token.email) || isSuperUser();
    }

    function isValidPublication(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000;
    }

    function isValidFinance(data) {
      return data.amount is number && data.userId is string && isValidId(data.userId);
    }

    function isValidAssociado(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && 'email' in request.auth.token && data.email == request.auth.token.email;
    }

    function isValidMember(data) {
      return data.cnpj is string && data.cnpj.size() <= 20 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['active', 'pending', 'inactive'] &&
             (data.keys().hasAll(['cnpj', 'name', 'email', 'status'])) &&
             (data.keys().size() >= 4);
    }

    function isValidBoleto(data) {
      return data.memberId is string && isValidId(data.memberId) &&
             data.title is string && data.title.size() <= 200 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['paid', 'pending', 'overdue'] &&
             data.keys().hasAll(['memberId', 'title', 'amount', 'dueDate', 'status']) &&
             data.keys().size() >= 5;
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.type in ['alert', 'info', 'event'] &&
             data.createdAt == request.time;
    }

    function isValidSuggestion(data) {
      return data.message is string && data.message.size() <= 5000 &&
             (data.userId == null || data.userId == request.auth.uid) &&
             data.createdAt == request.time;
    }

    function isValidFAQ(data) {
      return data.category is string && data.category.size() <= 100 &&
             data.question is string && data.question.size() <= 500 &&
             data.answer is string && data.answer.size() <= 2000 &&
             data.updatedAt == request.time;
    }

    function isValidMembershipRequest(data) {
      return data.companyName is string && data.companyName.size() <= 200 &&
             data.cnpj is string && data.cnpj.size() <= 20 &&
             data.email is string && data.email.size() <= 100 &&
             data.capitalSocial is number &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidLegalQuery(data) {
      return data.userId is string && isValidId(data.userId) &&
             data.companyCNPJ is string && data.companyCNPJ.size() <= 100 &&
             data.companyName is string && data.companyName.size() <= 1000 &&
             data.subject is string && data.subject.size() <= 1000 &&
             data.question is string && data.question.size() <= 15000 &&
             data.category is string && data.category.size() <= 500 &&
             data.urgency is string && data.urgency.size() <= 200 &&
             data.assignedLawyer is string && data.assignedLawyer.size() <= 500 &&
             data.assignedLawyerEmail is string && data.assignedLawyerEmail.size() <= 500 &&
             data.aiAnalysis is string && data.aiAnalysis.size() <= 25000 &&
             data.status in ['pending', 'replied'] &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /test/connection {
      allow read: if true;
    }

    match /admins/{email} {
      allow read: if isSignedIn() && ('email' in request.auth.token && request.auth.token.email == email || isAdmin());
      allow write: if isSuperUser();
    }

    match /members/{memberId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || ('email' in request.auth.token && resource.data.email == request.auth.token.email) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || ('email' in request.auth.token && resource.data.email == request.auth.token.email));
      
      allow create: if isSignedIn() || isAdmin();
      allow update: if (
        (isSignedIn() && (resource.data.userId == request.auth.uid || ('email' in request.auth.token && resource.data.email == request.auth.token.email)) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['userId', 'name', 'email', 'phone', 'representative'])) || 
        isAdmin()
      );
      allow delete: if isAdmin();

      // Sub-collection: Boletos
      match /boletos/{boletoId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/members/$(memberId)).data.userId == request.auth.uid || 
          ('email' in request.auth.token && get(/databases/$(database)/documents/members/$(memberId)).data.email == request.auth.token.email) || 
          isAdmin()
        );
        allow write: if isAdmin(); // Members cannot write boletos
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /systemSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /associateRequests/{docId} {
      allow read, write: if isAdmin();
    }

    match /expenses/{docId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true; // Public announcements
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /associados/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAssociado(incoming());
      allow update, delete: if isAdmin();
    }

    match /financeiro/{docId} {
      allow read, write: if isAdmin();
    }

    match /publicacoes/{docId} {
      allow read: if true; // Public view
      allow create, update, delete: if isAdmin() && isValidPublication(incoming());
    }

    match /suggestions/{suggestionId} {
      allow create: if isSignedIn() && isValidSuggestion(incoming());
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /faq/{faqId} {
      allow read: if true; // Publicly accessible FAQ
      allow write: if isAdmin() && isValidFAQ(incoming());
    }

    match /membership_requests/{requestId} {
      allow create: if isValidMembershipRequest(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /plantao_juridico/{queryId} {
      allow create: if isSignedIn() && isValidLegalQuery(incoming());
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['replyText', 'status']));
      allow delete: if isAdmin();
    }
  }
}
