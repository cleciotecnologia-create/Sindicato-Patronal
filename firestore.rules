rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperUser() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             (request.auth.token.email == 'cleciotecnologia@gmail.com' || request.auth.token.email == 'ianlima.sinpa@gmail.com');
    }

    // Admin check: checks UID in /usuarios/{uid} or /users/{uid} or token email
    function isAdmin() {
      return isSignedIn() && (
        isSuperUser() ||
        ('email' in request.auth.token && (
          request.auth.token.email == 'ianlima.sinpa@gmail.com' ||
          request.auth.token.email == 'cleciotecnologia@gmail.com' ||
          request.auth.token.email == 'admin@sinpa.org.br' ||
          request.auth.token.email.matches('(?i).*ian.*') ||
          request.auth.token.email.matches('(?i).*nicolas.*') ||
          request.auth.token.email.matches('(?i).*presidencia.*') ||
          request.auth.token.email.matches('(?i).*diretoria.*') ||
          request.auth.token.email.matches('(?i).*gerencia.*') ||
          request.auth.token.email.matches('(?i).*gerente.*') ||
          request.auth.token.email.matches('(?i).*admin.*') ||
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        )) ||
        (
          exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['admin', 'presidencia', 'diretoria', 'gerencia', 'gerente', 'Admin', 'ADMIN', 'Gestor', 'gestor'])
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'presidencia', 'diretoria', 'gerencia', 'gerente', 'Admin', 'ADMIN', 'Gestor', 'gestor'])
        )
      );
    }

    // --- Core User Collection Rules (usuarios/{userId} and users/{userId}) ---

    // Requirement: Strict UID-basedusuarios collection access
    match /usuarios/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Admin & System Configuration Collections ---
    match /admins/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admin_sessions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /systemSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Members & Company Data (Empresas) ---
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow delete: if isAdmin();

      match /boletos/{boletoId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /{path=**}/boletos/{boletoId} {
      allow read: if isSignedIn();
    }

    match /associateRequests/{docId} {
      allow read, write: if isAdmin();
    }

    // --- Financial & Union Management ---
    match /expenses/{docId} {
      allow read, write: if isAdmin();
    }

    match /financeiro/{docId} {
      allow read, write: if isAdmin();
    }

    match /associados/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Content & Communication ---
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /publicacoes/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /published_documents/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faq/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /plantao_juridico/{queryId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /membership_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /team_members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /vagas/{vagaId} {
      allow read: if true;
      allow write: if isAdmin() || isSignedIn();
    }

    match /push_subscriptions/{subscriptionId} {
      allow read, write: if isSignedIn() || isValidId(subscriptionId);
    }

    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
