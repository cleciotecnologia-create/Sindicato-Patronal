rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: assumes a collection /admins/ where docId is the email
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'cleciotecnologia@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isSuperUser() {
      return isSignedIn() && request.auth.token.email == 'cleciotecnologia@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validation Blueprints ---

    function isValidAdmin(data) {
      return data.email is string && data.email == request.auth.token.email || isSuperUser();
    }

    function isValidPublication(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000;
    }

    function isValidFinance(data) {
      return data.amount is number && data.userId is string && isValidId(data.userId);
    }

    function isValidAssociado(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200;
    }

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email == request.auth.token.email;
    }

    function isValidMember(data) {
      return data.cnpj is string && data.cnpj.size() <= 20 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['active', 'pending', 'inactive'] &&
             (data.keys().hasAll(['cnpj', 'name', 'email', 'status'])) &&
             (data.keys().size() >= 4);
    }

    function isValidBoleto(data) {
      return data.memberId is string && isValidId(data.memberId) &&
             data.title is string && data.title.size() <= 200 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['paid', 'pending', 'overdue'] &&
             data.keys().hasAll(['memberId', 'title', 'amount', 'dueDate', 'status']) &&
             data.keys().size() >= 5;
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.type in ['alert', 'info', 'event'] &&
             data.createdAt == request.time;
    }

    function isValidSuggestion(data) {
      return data.message is string && data.message.size() <= 5000 &&
             (data.userId == null || data.userId == request.auth.uid) &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /test/connection {
      allow read: if true;
    }

    match /admins/{email} {
      allow read: if isSignedIn() && (request.auth.token.email == email || isAdmin());
      allow write: if isSuperUser();
    }

    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if (isOwner(memberId) && isValidMember(incoming())) || isAdmin();
      allow update: if (
        (isOwner(memberId) && isValidMember(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])) || 
        isAdmin()
      );
      allow delete: if isAdmin();

      // Sub-collection: Boletos
      match /boletos/{boletoId} {
        allow read: if isOwner(memberId) || isAdmin();
        allow write: if isAdmin(); // Members cannot write boletos
      }
    }

    match /notifications/{notificationId} {
      allow read: if true; // Public announcements
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /associados/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAssociado(incoming());
      allow update, delete: if isAdmin();
    }

    match /financeiro/{docId} {
      allow read, write: if isAdmin();
    }

    match /publicacoes/{docId} {
      allow read: if true; // Public view
      allow create, update, delete: if isAdmin() && isValidPublication(incoming());
    }

    match /suggestions/{suggestionId} {
      allow create: if isSignedIn() && isValidSuggestion(incoming());
      allow read, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
  }
}
